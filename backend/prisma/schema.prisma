generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         String      @default("USER")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  initiatedRequests Request[]     @relation("Initiator")
  assignedTasks     RequestTask[]
  approvals         Approval[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model FlowTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        String
  isActive    Boolean    @default(true)
  steps       FlowStep[]
  requests    Request[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FlowStep {
  id                 String               @id @default(cuid())
  flowTemplateId     String
  flowTemplate       FlowTemplate         @relation(fields: [flowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  name               String
  description        String?
  requiredRole       String?
  requiresAttachment Boolean              @default(false)
  deadlineHours      Int?
  authLevels         AuthorizationLevel[]
  tasks              RequestTask[]
  createdAt          DateTime             @default(now())
}

model AuthorizationLevel {
  id                String   @id @default(cuid())
  flowStepId        String
  flowStep          FlowStep @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  name              String
  minValue          Float?
  maxValue          Float?
  requiredApprovers Int      @default(1)
  approverRole      String
  deadlineHours     Int?
}

model Request {
  id               String        @id @default(cuid())
  flowId           String
  flow             FlowTemplate  @relation(fields: [flowId], references: [id])
  initiatorId      String
  initiator        User          @relation("Initiator", fields: [initiatorId], references: [id])
  title            String
  description      String?
  status           String        @default("PENDING")
  currentStep      Int           @default(0)
  targetEmployee   String?
  targetDepartment String?
  startDate        String?
  amount           Float?
  currency         String        @default("BRL")
  supplier         String?
  costCenter       String?
  justification    String?
  tasks            RequestTask[]
  attachments      Attachment[]
  approvals        Approval[]
  auditLogs        AuditLog[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model RequestTask {
  id          String       @id @default(cuid())
  requestId   String
  request     Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId      String
  step        FlowStep     @relation(fields: [stepId], references: [id])
  assigneeId  String
  assignee    User         @relation(fields: [assigneeId], references: [id])
  title       String
  description String?
  status      String       @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id           String       @id @default(cuid())
  requestId    String?
  request      Request?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  taskId       String?
  task         RequestTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  storagePath  String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model Approval {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id])
  stepOrder  Int
  decision   String
  comments   String?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  details   String?
  createdAt DateTime @default(now())
}
