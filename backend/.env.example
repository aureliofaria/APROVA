# Copie para .env e ajuste os valores.

# Ambiente: "production" exige JWT_SECRET definido (a app não sobe sem ele).
NODE_ENV=development

# Porta da API
PORT=3001

# Segredo de assinatura dos tokens JWT.
# OBRIGATÓRIO em produção. Gere um valor forte, ex.: openssl rand -hex 32
JWT_SECRET=

# Origens permitidas para CORS (separadas por vírgula).
# Padrão de desenvolvimento: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# String de conexão do banco (Prisma/SQLite por padrão).
DATABASE_URL="file:./dev.db"
