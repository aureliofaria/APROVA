# Copie para .env e ajuste os valores.

# Ambiente: "production" exige JWT_SECRET definido (a app não sobe sem ele).
NODE_ENV=development

# Porta da API (e do app inteiro quando SERVE_FRONTEND=true).
PORT=3001

# Segredo de assinatura dos tokens JWT.
# OBRIGATÓRIO em produção. Gere um valor forte, ex.: openssl rand -hex 32
JWT_SECRET=

# Origens permitidas para CORS (separadas por vírgula).
# Dev: http://localhost:5173
# Rede interna em processo único: dispensável (frontend na mesma origem).
CORS_ORIGIN=http://localhost:5173

# String de conexão do banco (Prisma/SQLite por padrão).
DATABASE_URL="file:./dev.db"

# Servir o frontend (build em frontend/dist) pelo próprio backend.
# Ative no deploy de processo único na rede interna (acesso por http://<ip>:PORT).
# Deixe false em desenvolvimento (use o Vite em :5173).
SERVE_FRONTEND=false

# Notificações por canais externos (Teams/Outlook). Mantenha false até haver
# conta corporativa M365 + validação humana — hoje só IN_APP é entregue.
NOTIFICATIONS_EXTERNAL_ENABLED=false

# Intervalo (ms) do agendador in-process de escalonamento temporal (Passo 11).
# Só roda quando o backend é executado diretamente (não em testes). Padrão 600000 (10 min).
ESCALATION_INTERVAL_MS=600000

# ───────────────────────────────────────────────────────────────────────────
# Microsoft Graph (client credentials) — App Registration compartilhada entre
# o envio de e-mail (notificações) e a sincronização de usuários abaixo.
# Permissões de aplicação necessárias: Mail.Send (notificações) +
# User.Read.All (sync de usuários), com consent de admin no tenant Gol Plus.
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_SENDER=aprova@golplus.com.br

# Sincronização de usuários com o M365/Entra ID (fonte da verdade de quem
# pode acessar o APROVA). Desligada por padrão — ligue só após validar com
# M365_USER_SYNC_DRY_RUN=true. Requer GRAPH_* configurado acima.
M365_USER_SYNC_ENABLED=false
# Intervalo (ms) do agendador in-process. Padrão 21600000 (6h).
M365_USER_SYNC_INTERVAL_MS=21600000
# true: calcula e loga os contadores (criados/ativados/desativados/ignorados)
# sem gravar nada no banco. Use para validar antes de ligar de fato.
M365_USER_SYNC_DRY_RUN=false

# ───────────────────────────────────────────────────────────────────────────
# Exemplo de produção em servidor local / rede interna (processo único):
#   NODE_ENV=production
#   PORT=80
#   JWT_SECRET=<openssl rand -hex 32>
#   DATABASE_URL="file:./dev.db"
#   SERVE_FRONTEND=true
#   # CORS_ORIGIN pode ficar como está — mesma origem dispensa CORS.
# ───────────────────────────────────────────────────────────────────────────
